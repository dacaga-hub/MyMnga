{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:allow-open",
    "dialog:allow-message",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-read-text-file",
    "fs:allow-stat",
    "fs:allow-exists",
    "fs:scope",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load"
  ]
}